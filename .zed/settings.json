{
   // "file_scan_inclusions": [".todo/*"],
   "file_scan_exclusions": [
      "web/**/*.js", // hide generated files
      ".todo/*",
      // defaults
      "**/.git",
      "**/.DS_Store"
   ],
   "lsp": {
      // https://github.com/zed-industries/zed/issues/4660
      "gopls": {
         // "binary": {
         //   "path": "/Users/thorstenball/bin/gopls",
         //   "arguments": ["-debug=0.0.0.0:9090"]
         // },
         "initialization_options": {
            // https://github.com/golang/tools/blob/master/gopls/doc/settings.md
            "usePlaceholders": true,
            "buildFlags": ["-tags=integration"],
            "completeUnimported": true,
            "experimentalPostfixCompletions": true,
            "templateExtensions": ["gohtml"],
            "directoryFilters": ["-", "+internal", "+cmd", "+web"],
            "hints": {
               "assignVariableTypes": false,
               "compositeLiteralFields": false,
               "compositeLiteralTypes": false,
               "constantValues": true,
               "functionTypeParameters": true,
               "parameterNames": true,
               "rangeVariableTypes": true
            }
         }
      },
      "gozer": {
         "initialization_options": {
            "printWidth": 120,
            "attrWrapMode": "all"
         }
      },
      "gossamer": {
         "initialization_options": {
            "printWidth": 120,
            "formatMode": "detect"
         }
      }
   },
   "file_types": { "Go HTMX 4": ["gohtml"] },
   "languages": {
      "SQL": {
         "formatter": "language_server",
         "format_on_save": "on",
         "language_servers": ["postgres-language-server", "!gopls"]
      },
      "Go HTMX 4": {
         "format_on_save": "on",
         "tab_size": 3,
         "hard_tabs": false,
         "formatter": {
            "language_server": { "name": "gozer" }
         },
         "language_servers": ["gozer", "!gopls"] // "vscode-html-language-server",
      },
      "CSS": {
         "formatter": "language_server",
         "format_on_save": "on",
         "code_actions_on_format": {
            "source.fixAll": true
         },
         "language_servers": ["gossamer", "!gopls"]
      },
      "TypeScript": {
         "language_servers": ["vtsls", "biome", "!gopls"]
      }
   }
}
