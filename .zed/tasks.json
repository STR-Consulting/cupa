[
   {
      "label": "Build",
      "command": "mise run build",
      "tags": ["build"]
   },
   {
      "label": "Start Databases",
      "command": "mise run db:start",
      "reveal": "never",
      "hide": "on_success",
      "tags": ["db"]
   },
   {
      "label": "Stop Databases",
      "command": "mise run db:stop",
