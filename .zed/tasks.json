      "command": "mise run deploy:prod",
      "use_new_terminal": true,
      "tags": ["deploy"]
   },
   {
      "label": "Deploy to Test",
      "command": "mise run deploy:test",
      "use_new_terminal": true,
      "tags": ["deploy"]
   },
