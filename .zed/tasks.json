   },
   {
      "label": "go test (unit)",
      "command": "go test -v $ZED_RELATIVE_FILE -run $ZED_SYMBOL",
      "tags": ["go-test"]
   },
   {
      "label": "Run Unit Tests",
      "command": "mise run test",
      "use_new_terminal": true,
      "tags": ["test"]
   },
   {
      "label": "Run SQL Tests",
      "command": "mise run test:sql",
      "use_new_terminal": true,
      "tags": ["test"]
   },
   {
      "label": "Run Integration Tests",
      "command": "mise run test:integration",
      "use_new_terminal": true,
      "tags": ["test"]
   },
   {
      "label": "go test (integration)",
      "command": "doppler run -p pacer -c dev -- go test -tags=integration -v $ZED_RELATIVE_FILE -run $ZED_SYMBOL",
      "tags": ["go-test"]
   },
   {
      "label": "go test package (integration)",
      "command": "doppler run -p pacer -c dev -- go test -tags=integration -v ./...",
